<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.ereader.simple">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Read connectivity state so the offline app shell (#23) knows when to
         serve bundled assets vs load live from the server. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- Background audiobook playback + lock-screen / headphone media controls. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.AppCompat.NoActionBar"
        android:usesCleartextTraffic="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|keyboardHidden|keyboard|navigation|density|uiMode" />

        <!-- Launcher-icon variants as aliases (#242). MainActivity has no launcher
             entry of its own; exactly ONE alias is enabled at a time, toggled at
             runtime by JsBridge.setLauncherIcon() via setComponentEnabledSetting
             (no rebuild). Default = default (enabled); the rest disabled. Alias names
             must match MainActivity.aliasFor(): "Icon" + CamelCase(variant). -->
        <activity-alias android:name=".IconDefault" android:enabled="true" android:exported="true"
            android:targetActivity=".MainActivity" android:label="@string/app_name"
            android:icon="@mipmap/ic_launcher_default" android:roundIcon="@mipmap/ic_launcher_default_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".IconRed" android:enabled="false" android:exported="true"
            android:targetActivity=".MainActivity" android:label="@string/app_name"
            android:icon="@mipmap/ic_launcher_red" android:roundIcon="@mipmap/ic_launcher_red_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".IconBlue" android:enabled="false" android:exported="true"
            android:targetActivity=".MainActivity" android:label="@string/app_name"
            android:icon="@mipmap/ic_launcher_blue" android:roundIcon="@mipmap/ic_launcher_blue_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".IconPurple" android:enabled="false" android:exported="true"
            android:targetActivity=".MainActivity" android:label="@string/app_name"
            android:icon="@mipmap/ic_launcher_purple" android:roundIcon="@mipmap/ic_launcher_purple_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".IconPride" android:enabled="false" android:exported="true"
            android:targetActivity=".MainActivity" android:label="@string/app_name"
            android:icon="@mipmap/ic_launcher_pride" android:roundIcon="@mipmap/ic_launcher_pride_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".IconLesbian" android:enabled="false" android:exported="true"
            android:targetActivity=".MainActivity" android:label="@string/app_name"
            android:icon="@mipmap/ic_launcher_lesbian" android:roundIcon="@mipmap/ic_launcher_lesbian_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".IconBiPride" android:enabled="false" android:exported="true"
            android:targetActivity=".MainActivity" android:label="@string/app_name"
            android:icon="@mipmap/ic_launcher_bi_pride" android:roundIcon="@mipmap/ic_launcher_bi_pride_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias android:name=".IconWhite" android:enabled="false" android:exported="true"
            android:targetActivity=".MainActivity" android:label="@string/app_name"
            android:icon="@mipmap/ic_launcher_white" android:roundIcon="@mipmap/ic_launcher_white_round">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Foreground media service: keeps the WebView audiobook playing when
             the screen locks / the app is backgrounded (Android otherwise
             freezes the cached process after a few minutes, stalling hls.js),
             and owns the MediaSession that hardware/headphone buttons drive.
             The MEDIA_BUTTON intent-filter lets media keys reach it while the
             app is in the background. -->
        <service
            android:name=".PlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </service>

        <!-- Routes hardware media-button broadcasts to the active MediaSession. -->
        <receiver
            android:name="androidx.media.session.MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

        <!-- FileProvider used by JsBridge.shareImage() to expose canvas PNGs
             written into cacheDir/share as content:// URIs that ACTION_SEND
             can hand to other apps (Photos / Gmail / Messages / etc). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
